# Backend environment variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Your Supabase project URL
# Found in: Supabase dashboard > Project Settings > API > Project URL
SUPABASE_URL=

# Your Supabase service role key (NOT the anon key)
# Found in: Supabase dashboard > Project Settings > API > Project API keys > service_role
# Keep this secret - it bypasses Row Level Security
SUPABASE_SERVICE_ROLE_KEY=

# Your Supabase JWT secret
# Found in: Supabase dashboard > Project Settings > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=

# Comma-separated list of production frontend origins allowed to call this
# API (CORS). http://localhost:3000 is always allowed automatically for
# local dev - you don't need to add it here.
# Example: https://calibration-pwa.vercel.app,https://calibration-pwa-git-main.vercel.app
ALLOWED_ORIGINS=
