# Backend environment variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Your Supabase project URL
# Found in: Supabase dashboard > Project Settings > API > Project URL
SUPABASE_URL=

# Your Supabase service role key (NOT the anon key)
# Found in: Supabase dashboard > Project Settings > API > Project API keys > service_role
# Keep this secret - it bypasses Row Level Security
SUPABASE_SERVICE_ROLE_KEY=

# Your Supabase JWT secret
# Found in: Supabase dashboard > Project Settings > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=
